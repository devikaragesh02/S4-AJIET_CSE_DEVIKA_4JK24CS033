class Main {
    public static void main(String[] args) {
    int temp;
    
    int a=2;
    int b=3;
    {
    temp=a;
    a=b;
    b=temp;
    }
    {
    temp=b;
    b=a;
    a=temp;
    }
    {
        int c=a;
        temp=a;
        a=c;
        c=temp;
    }
    
      
    System.out.println("after swapping");
    System.out.println("a="+a);
    System.out.println("b="+b);
    
    }
}
