public class Main
{
	public static void main(String[] args) {
	    String s="hello";
        String rev = new StringBuilder(s).reverse().toString();
        for(int i=0;i<s.length();i++)
        {
            rev=s.charAt(i)+rev;
        }
            if (s.equals(rev))
            {
                System.out.println("palindrome");
            }
            else
            {
                System.out.print("not palindrome");
            }
    }
}
